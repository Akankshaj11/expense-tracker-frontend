export function translateText(language, key, values = {}) {
  const template = translations[language]?.[key] || translations.en[key] || key
  return String(template).replace(/\{(\w+)\}/g, (_, valueKey) => String(values[valueKey] ?? ''))
}

export function getLocale(language) {
  return language === 'mr' ? 'mr-IN' : 'en-US'
}

export function translateModuleLabel(language, moduleName) {
  const key = String(moduleName || '').toLowerCase()
  return translations[language]?.moduleLabels?.[key] || translations.en.moduleLabels?.[key] || moduleName
}

export default translations
